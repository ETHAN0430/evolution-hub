(function () {
  "use strict";
  var SDK = window.__HERMES_PLUGIN_SDK__;
  if (!SDK || !window.__HERMES_PLUGINS__) return;
  var React = SDK.React;
  var hooks = SDK.hooks;
  var h = React.createElement;

  var BASE = '/api/plugins/hermes-evolution-hub';
  var token = (typeof window.__HERMES_SESSION_TOKEN__ === 'string') ? window.__HERMES_SESSION_TOKEN__ : '';
  var authHeaders = token ? {'X-Hermes-Session-Token': token} : {};

  function authFetch(url) {
    return fetch(url, {headers: authHeaders});
  }

  // Node click data
  var NODES = {
    'Hermes CLI': ['hermes_cli/main.py'],
    'Dashboard': ['hermes_cli/web_server.py'],
    'Desktop': ['apps/desktop/electron/main.cjs'],
    'Gateway': ['hermes_cli/gateway.py'],
    'Messaging Platforms': ['gateway/platforms/telegram.py'],
    'Turn 前奏': ['turn_context.py'],
    '系统提示': ['system_prompt.py'],
    '消息构建': ['prompt_builder.py'],
    '主循环': ['conversation_loop.py'],
    'LLM API': ['conversation_loop.py'],
    '工具执行': ['tool_executor.py'],
    'memory tool': ['tools/memory_tool.py'],
    '上下文压缩': ['context_compressor.py'],
    'Turn 收尾': ['turn_finalizer.py'],
    '背景 review': ['background_review.py'],
    'MemoryManager': ['memory_manager.py'],
    'MemoryProvider': ['memory_provider.py'],
    'MemoryStore': ['tools/memory_tool.py'],
    'ContextEngine': ['context_engine.py'],
    'ContextCompressor': ['context_compressor.py'],
    'Vector DB': ['vector_store_chroma.py'],
    'Provider APIs': ['agent/anthropic_adapter.py'],
    'Config & State': ['hermes_cli/config.py'],
    'HY Memory': ['hy_memory/client.py'],
    'S1 Writer': ['hy_memory/pipelines/writer.py'],
    'MemAgent': ['hy_memory/agent/mem_agent.py'],
    'Reconciler': ['hy_memory/agent/reconciler.py'],
    'cache.db': ['hy_memory/data/cache_sqlite.py'],
    'System 2': ['hy_memory/pipelines/system2_writer.py'],
    'Graph DB': ['hy_memory/data/graph_store_kuzu.py'],
    'SQLite Session': ['run_agent.py'],
    '用户': ['run_agent.py'],
    '记忆文件': ['tools/memory_tool.py']
  };

  function resolvePath(src) {
    var base = '/home/cyf/.hermes/hermes-agent/';
    if (src.startsWith('/')) return src;
    if (src.startsWith('hy_memory/')) return base + 'venv/lib/python3.11/site-packages/' + src;
    if (src === 'run_agent.py') return base + src;
    if (src.startsWith('hermes_cli/') || src.startsWith('gateway/') || src.startsWith('apps/')) return base + src;
    if (src.startsWith('tools/')) return base + src;
    if (src.startsWith('agent/')) return base + src;
    return base + 'agent/' + src;
  }

  function EvolutionHubPage() {
    var _a = hooks.useState(null), svgText = _a[0], setSvgText = _a[1];
    var _b = hooks.useState(null), health = _b[0], setHealth = _b[1];
    var _c = hooks.useState(null), agentLoop = _c[0], setAgentLoop = _c[1];
    var _d = hooks.useState('加载架构图中…'), loadMsg = _d[0], setLoadMsg = _d[1];
    var _e = hooks.useState(1), svgScale = _e[0], setSvgScale = _e[1];
    var _f = hooks.useState(null), detail = _f[0], setDetail = _f[1];
    var _g = hooks.useState(0), posX = _g[0], setPosX = _g[1];
    var _h = hooks.useState(0), posY = _h[0], setPosY = _h[1];
    var svgRef = hooks.useRef(null);
    var dragRef = hooks.useRef(false);
    var dragStartRef = hooks.useRef({x:0, y:0});
    var posRef = hooks.useRef({x:0, y:0});

    function onMouseDown(e) {
      if (e.button !== 0) return;
      dragRef.current = true;
      dragStartRef.current = {x: e.clientX - posRef.current.x, y: e.clientY - posRef.current.y};
      e.currentTarget.style.cursor = 'grabbing';
    }

    function onMouseMove(e) {
      if (!dragRef.current) return;
      var nx = e.clientX - dragStartRef.current.x;
      var ny = e.clientY - dragStartRef.current.y;
      posRef.current = {x: nx, y: ny};
      setPosX(nx);
      setPosY(ny);
    }

    function onMouseUp(e) {
      if (!dragRef.current) return;
      dragRef.current = false;
      e.currentTarget.style.cursor = 'grab';
    }

    function onMouseLeave(e) {
      if (!dragRef.current) return;
      dragRef.current = false;
      e.currentTarget.style.cursor = 'grab';
    }

    hooks.useEffect(function () {
      Promise.all([
        authFetch(BASE + '/architecture.svg').then(function (r) { return r.text(); }),
        authFetch(BASE + '/api/health').then(function (r) { return r.json(); }).catch(function () { return null; }),
        authFetch(BASE + '/api/agent-loop').then(function (r) { return r.json(); }).catch(function () { return null; })
      ]).then(function (results) {
        setSvgText(results[0]);
        setHealth(results[1]);
        setAgentLoop(results[2]);
      }).catch(function (e) {
        setLoadMsg('加载失败: ' + e.message);
      });
    }, []);

    // Attach click handlers after SVG renders
    hooks.useEffect(function () {
      if (!svgText || !svgRef.current) return;
      var svgEl = svgRef.current.querySelector('svg');
      if (!svgEl) return;
      var groups = svgEl.querySelectorAll('g[transform]');
      groups.forEach(function (g) {
        var text = g.querySelector('text');
        if (!text) return;
        var name = text.textContent.trim();
        if (!NODES[name]) return;
        g.style.cursor = 'pointer';
        g.addEventListener('click', function (e) {
          e.stopPropagation();
          var src = NODES[name][0], path = resolvePath(src);
          setDetail({name: name, src: src, path: path, code: null, loading: true});
          authFetch(BASE + '/api/source?path=' + encodeURIComponent(path))
            .then(function (r) { return r.json(); })
            .then(function (d) {
              setDetail(function (prev) {
                return prev && prev.name === name
                  ? {name: prev.name, src: prev.src, path: prev.path, code: d.content || ('Error: ' + (d.error || 'unknown')), loading: false}
                  : prev;
              });
            })
            .catch(function (e) {
              setDetail(function (prev) {
                return prev && prev.name === name
                  ? {name: prev.name, src: prev.src, path: prev.path, code: 'Error: ' + e.message, loading: false}
                  : prev;
              });
            });
        });
      });
    }, [svgText]);

    var srv = health && health.server || {};
    var isOk = srv.vdb === 'ok' || srv.llm === 'ok';
    var transformStyle = 'translate(' + posX + 'px,' + posY + 'px) scale(' + svgScale + ')';

    return h('div', {style: {height: '100%', display: 'flex', flexDirection: 'column', background: '#041c1c', color: '#ffe6cb', fontFamily: "system-ui,-apple-system,'Segoe UI',sans-serif", fontSize: '14px'}},
      // Header
      h('div', {style: {padding: '20px 24px', borderBottom: '1px solid #1a4a4a', background: 'linear-gradient(135deg,#0a2e2e 0%,rgba(103,232,249,0.08) 100%)'}},
        h('div', {style: {color: '#c4a882', textTransform: 'uppercase', letterSpacing: '0.18em', fontSize: '11px', fontFamily: "ui-monospace,'SF Mono',Menlo,monospace"}}, 'Hermes Evolution Hub'),
        h('div', {style: {fontSize: 'clamp(1.8rem, 3.5vw, 3.2rem)', fontWeight: 750, letterSpacing: '-0.05em'}}, '进化中枢'),
        h('div', {style: {marginTop: '8px', color: '#c4a882', fontSize: '13px', lineHeight: 1.5, maxWidth: '42rem'}}, 'Hermes 架构图、HY Memory 进化引擎与系统健康状态的可视化面板。点击模块查看源码路径与连接关系。'),
      ),
      // Controls bar
      h('div', {style: {display: 'flex', gap: '6px', alignItems: 'center', padding: '8px 16px', borderBottom: '1px solid #1a4a4a', background: 'rgba(255,255,255,0.02)', flexWrap: 'wrap'}},
        // Zoom buttons
        h('button', {onClick: function () { setSvgScale(Math.max(0.35, Math.min(2.5, svgScale - 0.15))); }, style: btnStyle}, '−'),
        h('button', {onClick: function () { setSvgScale(Math.max(0.35, Math.min(2.5, svgScale + 0.15))); }, style: btnStyle}, '+'),
        h('button', {onClick: function () { setSvgScale(1); setPosX(0); setPosY(0); posRef.current = {x:0, y:0}; }, style: btnStyle}, '重置'),
        h('div', {style: {marginLeft: 'auto', display: 'flex', gap: '8px', alignItems: 'center', fontSize: '11px', color: '#c4a882', fontFamily: "ui-monospace,'SF Mono',Menlo,monospace"}},
          h('span', {style: {display: 'flex', alignItems: 'center', gap: '4px'}},
            h('span', {style: {width: '8px', height: '8px', borderRadius: '50%', background: isOk ? '#4ade80' : '#ef4444', boxShadow: isOk ? '0 0 8px #4ade80' : '0 0 8px #ef4444'}}),
            '服务: ', h('b', null, svgText ? (isOk ? '正常' : '异常') : '检测中')
          ),
          h('span', null, 'VDB: ', h('b', null, srv.vdb_points || '?')),
          h('span', null, 'API: ', h('b', null, agentLoop ? agentLoop.total_api : '?')),
        )
      ),
      // SVG canvas
      h('div', {style: {flex: 1, overflow: 'hidden', display: 'flex', alignItems: 'center', justifyContent: 'center', padding: '24px', background: 'rgba(0,0,0,0.2)', cursor: 'grab'}, onMouseDown: onMouseDown, onMouseMove: onMouseMove, onMouseUp: onMouseUp, onMouseLeave: onMouseLeave},
        svgText
          ? h('div', {ref: svgRef, style: {background: '#0d3333', border: '1px solid #1a4a4a', boxShadow: '0 0 60px rgba(103,232,249,0.1),0 20px 60px rgba(0,0,0,0.5)', lineHeight: 0, transform: transformStyle, transformOrigin: '0 0'}},
              h('div', {dangerouslySetInnerHTML: {__html: svgText}})
            )
          : h('div', {style: {color: '#c4a882', fontFamily: "ui-monospace,'SF Mono',Menlo,monospace", padding: '48px', textAlign: 'center'}}, loadMsg),
      ),
      // Detail panel
      detail ? h('div', {style: {
        position: 'fixed', right: 0, top: 0, bottom: 0, width: 'min(420px,90vw)',
        borderLeft: '1px solid #1a4a4a', background: 'rgba(18,21,28,0.96)',
        boxShadow: '-12px 0 40px rgba(0,0,0,0.45)', zIndex: 50,
        display: 'flex', flexDirection: 'column'
      }},
        h('div', {style: {display: 'flex', justifyContent: 'space-between', alignItems: 'center', gap: '12px', padding: '14px 16px', borderBottom: '1px solid #1a4a4a'}},
          h('strong', {style: {fontSize: '13px', textTransform: 'uppercase', letterSpacing: '0.1em', fontFamily: "ui-monospace,'SF Mono',Menlo,monospace"}}, detail.name),
          h('button', {onClick: function () { setDetail(null); }, style: {width: '30px', height: '30px', display: 'grid', placeItems: 'center', border: '1px solid #1a4a4a', background: 'transparent', color: '#c4a882', fontSize: '18px', cursor: 'pointer', borderRadius: 0}}, '×'),
        ),
        h('div', {style: {padding: '14px 16px', display: 'flex', flexDirection: 'column', gap: '14px', overflow: 'auto'}},
          h('div', {style: {border: '1px solid #1a4a4a', background: 'rgba(255,255,255,0.03)', padding: '12px 14px'}},
            h('strong', {style: {display: 'block', marginBottom: '6px', fontSize: '11px', textTransform: 'uppercase', letterSpacing: '0.1em', fontFamily: "ui-monospace,'SF Mono',Menlo,monospace", color: '#c4a882'}}, '源码文件'),
            h('p', {style: {margin: 0, fontSize: '13px', color: '#d4bfa0', lineHeight: 1.5}}, detail.src),
          ),
          h('div', {style: {border: '1px solid #1a4a4a', background: 'rgba(255,255,255,0.03)', padding: '12px 14px', overflow: 'auto', maxHeight: '60vh'}},
            h('strong', {style: {display: 'block', marginBottom: '6px', fontSize: '11px', textTransform: 'uppercase', letterSpacing: '0.1em', fontFamily: "ui-monospace,'SF Mono',Menlo,monospace", color: '#c4a882'}}, detail.loading ? '加载中…' : '源码预览'),
            h('pre', {style: {margin: 0, fontSize: '11px', lineHeight: 1.5, color: '#d4bfa0', whiteSpace: 'pre', overflow: 'auto', maxHeight: '50vh'}}, detail.loading ? '正在加载…' : (detail.code || '无法加载')),
          ),
        ),
      ) : null,
    );
  }

  var btnStyle = {
    border: '1px solid #1a4a4a', background: 'rgba(18,21,28,0.72)', color: '#c4a882',
    padding: '5px 10px', fontSize: '11px', cursor: 'pointer',
    fontFamily: "ui-monospace,'SF Mono',Menlo,monospace", textTransform: 'uppercase', letterSpacing: '0.06em'
  };

  window.__HERMES_PLUGINS__.register('hermes-evolution-hub', EvolutionHubPage);
})();
